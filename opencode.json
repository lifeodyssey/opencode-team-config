{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode-slim",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "gsd-opencode",
    "@plannotator/opencode@0.19.3",
    "opencode-ralph-loop",
    "cc-safety-net@0.6.0",
    "opencode-worktree",
    "opencode-agent-skills@0.6.4",
    "@tarquinen/opencode-dcp",
    "opencode-working-memory",
    "context-mode"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@github/mcp-server"],
      "enabled": true,
      "environment": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      }
    },
    "azure-devops": {
      "type": "local",
      "command": ["npx", "-y", "@azure-devops/mcp", "{env:AZURE_DEVOPS_ORG}"],
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa",
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": ["npx", "-y", "@anthropic/mcp-server-postgres", "{env:DATABASE_URL}"],
      "enabled": false
    }
  }
}
