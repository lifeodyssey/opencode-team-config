{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@plannotator/opencode@latest",
    "oh-my-opencode",
    "opencode-froggy",
    "opencode-ralph-loop",
    "cc-safety-net",
    "opencode-worktree",
    "opencode-agent-skills"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "astro-docs": {
      "type": "remote",
      "url": "https://mcp.docs.astro.build/mcp",
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@github/mcp-server"],
      "enabled": true,
      "environment": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      }
    },
    "azure-devops": {
      "type": "local",
      "command": ["npx", "-y", "@azure-devops/mcp", "{env:AZURE_DEVOPS_ORG}"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "{cwd}"
      ],
      "enabled": true,
      "environment": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  },
  "agent": {
    "sisyphus":          { "model": "github-copilot/claude-opus-4.6" },
    "oracle":            { "model": "github-copilot/claude-opus-4.6" },
    "metis":             { "model": "github-copilot/claude-opus-4.6" },
    "atlas":             { "model": "github-copilot/claude-opus-4.6" },
    "prometheus":        { "model": "github-copilot/claude-opus-4.6" },
    "hephaestus":        { "model": "github-copilot/claude-sonnet-4.6" },
    "momus":             { "model": "github-copilot/claude-sonnet-4.6" },
    "explore":           { "model": "github-copilot/claude-sonnet-4.6" },
    "multimodal-looker": { "model": "github-copilot/claude-sonnet-4.6" },
    "librarian":         { "model": "github-copilot/claude-haiku-4.5" }
  }
}
