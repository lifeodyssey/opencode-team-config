# Required
export AZURE_DEVOPS_ORG=your-org-name

# GitHub (reuses gh CLI session, no PAT needed)
export GITHUB_TOKEN=$(gh auth token)

# Optional
export EXA_API_KEY=your-key              # Exa web search (free: 1000 req/mo at exa.ai)
export DATABASE_URL=postgres://...        # For postgres MCP (disabled by default in opencode.json)
